{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-manifest-spec.org/schema/academic-surface/version.schema.json",
  "title": "Version",
  "description": "A Version record inside a Work's versions[]. Work and Version are distinct records (invariant SSOT, acta §5.A). doi_version lives ONLY here (ASV-VER-003).",
  "type": "object",
  "required": ["id", "vN", "date", "is_current"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1, "description": "Stable Version id, distinct from the Work id." },
    "vN": { "type": "string", "pattern": "^v\\d+$", "description": "Monotonic label v1, v2, ..." },
    "label": { "type": "string" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "ISO date; drives citation_publication_date (ASV-VER-002)." },
    "doi_version": { "type": "string", "description": "Version DOI; distinct from the Work's doi_concept." },
    "is_current": { "type": "boolean", "description": "Exactly one Version per Work is current (ASV-VER-004)." },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "artifact.schema.json" }
    },
    "changelog": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Append-only (ASV-VER-006)."
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "relation.schema.json" }
    },
    "provenance": { "$ref": "provenance.schema.json" },
    "web": {
      "type": "object",
      "additionalProperties": false,
      "description": "Declared surface directives for the frozen /vN page (validated for invariant compliance before materialization).",
      "properties": {
        "path": { "type": "string" },
        "canonical": { "type": "string" }
      }
    }
  }
}
