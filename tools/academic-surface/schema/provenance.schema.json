{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-manifest-spec.org/schema/academic-surface/provenance.schema.json",
  "title": "Provenance",
  "description": "PROV-O-inspired provenance separating three roles: intellectual author (human), record creator (human), and build activity (a tool). A tool may appear ONLY under build_activity, never as author/contributor (ASV-PROV-002/003).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intellectual_author": { "$ref": "#/$defs/humanAgent" },
    "record_creator": { "$ref": "#/$defs/humanAgent" },
    "build_activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool"],
      "properties": {
        "tool": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "type_discrepancies": {
      "type": "array",
      "description": "External metadata type conflicts recorded observationally (V-A); NEVER a second canonical type.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "value"],
        "properties": {
          "source": { "type": "string", "enum": ["orcid", "zenodo", "datacite", "crossref", "other"] },
          "value": { "type": "string" }
        }
      }
    },
    "external_metadata": {
      "type": "object",
      "description": "Mirror of external-registry metadata for observation only (e.g. Zenodo language 'enc'). Never authoritative for the surface.",
      "additionalProperties": false,
      "properties": {
        "language_observed": { "type": "string" },
        "relation_observed": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "methodological_notes": {
      "type": "string",
      "description": "Free-text non-authorial notes; the only place technical/AI assistance may be mentioned (ASV-PROV-004)."
    }
  },
  "$defs": {
    "humanAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "is_human"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "is_human": { "type": "boolean" },
        "orcid": { "type": "string", "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[\\dX]$" }
      }
    }
  }
}
