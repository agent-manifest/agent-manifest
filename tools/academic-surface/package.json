{
  "name": "@agent-manifest/academic-surface-validator",
  "version": "0.0.0",
  "private": true,
  "description": "Gate C — local structural and semantic validator for the Academic Surface Work Record contract (Gate A) and validation specification (Gate B). Internal repository tooling; not a public surface; not published.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "validate": "node ./bin/academic-surface.js validate",
    "isolation-check": "node ./src/isolation-check.js",
    "derive": "node ./src/derive.js",
    "stage": "node ./src/build-site.js",
    "publish-site": "node ./src/publish-site.js",
    "publish-check": "node ./src/publish-site.js --check",
    "preview": "python3 -m http.server -d staging 8081"
  },
  "keywords": [
    "academic-surface",
    "validator",
    "json-schema",
    "gate-c",
    "internal-tooling"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
